# Required for Auth.js sessions (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
# Authorization callback URL: https://YOUR_DOMAIN/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: set in production if Auth.js cannot detect the host
# AUTH_URL=https://YOUR_DOMAIN
AUTH_TRUST_HOST=true
